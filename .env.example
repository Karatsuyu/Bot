# Telegram API Credentials
# Obtén estos valores desde: https://my.telegram.org/apps
API_ID=123456
API_HASH=abcdef123456

# Bot Token
# Obtén este token desde @BotFather en Telegram
BOT_TOKEN=123456:ABCDEF

# Database Connection
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_bd
DATABASE_URL=postgresql://user:password@localhost/telegram_archive

# Control Bot ID (opcional)
# Usuario para recibir notificaciones (por defecto: "me" = el usuario autenticado)
CONTROL_BOT_ID=me

# Backup en modo tema (topic) - Opcional
# ID del supergrupo con temas activados para backup
# Deja vacío o comenta para usar solo backup por canales
BACKUP_GROUP_ID=-1003815939266

# Modo de backup: 'channel' (por defecto) o 'topic'
# channel: Crea canales privados para cada grupo
# topic: Usa temas en un supergrupo compartido
BACKUP_MODE=channel

# Límites y delays (opcional)
SCAN_LIMIT_PER_RUN=200
JOIN_LIMIT_PER_RUN=10
JOIN_DELAY_SECONDS=30
